# ------------------------------------------------------------------
# Terraform exclusions
# Source: https://github.com/github/gitignore/blob/main/Terraform.gitignore
# ------------------------------------------------------------------

# Local.terraform directories
**/.terraform/*

# Terraform state files
*.tfstate
*.tfstate.*

# Crash logs
crash.log
crash.*.log

# Variable files (may contain sensitive data)
*.tfvars
*.tfvars.json

# Override files (local use only)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform CLI configuration
.terraformrc
terraform.rc

# ------------------------------------------------------------------
# Editor / tooling exclusions
# ------------------------------------------------------------------

# VS Code (only commit if sharing team settings)
.vscode/

# Azure CLI local context
.azure/

# Temporary / backup files
*~
*.old
*.disabled

# Work-in-progress files
WIP/*

# ------------------------------------------------------------------
# CI / pipeline artefacts
# ------------------------------------------------------------------

artifacts/
logs/
